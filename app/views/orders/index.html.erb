<div>
  <h1 class="font-bold text-4xl">Orders</h1>
</div>

<div>
  <table class="table">
    <caption>
      A list of orders.
    </caption>
    <thead>
      <tr>
        <th>ID</th>
        <th>Customer</th>
        <th>Date</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <th><%= order.id %></th>
          <td><%= order.customer.full_name %></td>
          <td><%= order.order_date.strftime("%d/%m/%Y %H:%M") %></td>          
          <td><%= order.status %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>